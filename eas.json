{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "releaseStatus": "draft"
      },
      "ios": {
        "ascApiKeyPath": "./auth.p8",
        "ascApiKeyIssuerId": "${{ env.ASC_API_KEY_ISSUER_ID }}",
        "ascApiKeyId": "${{ env.ASC_API_KEY_ID }}"
      }
    }
  }
}
